# ---- mode ----
# live  = real collectors hit the live APIs (default)
# demo  = dummy data (no internet, no keys needed) — offline preview only
DATA_MODE=live

# ---- CORS: which frontend origins may call this API (comma-separated) ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- analysis: the AI agent decides everything; pick the provider ----
ANALYSIS=llm
LLM_PROVIDER=gemini

# ---- MongoDB (text & events) ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=media_risk

# ---- PostgreSQL (prices & numbers) ----
PG_HOST=localhost
PG_PORT=5432
PG_DB=media_risk
PG_USER=postgres
PG_PASSWORD=postgres

# ---- Google Gemini (used when LLM_PROVIDER=gemini) — https://aistudio.google.com/apikey ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Anthropic Claude (used when LLM_PROVIDER=anthropic) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- optional news API keys for live mode (free tiers) ----
GNEWS_KEY=
FINNHUB_KEY=
NEWSAPI_KEY=
